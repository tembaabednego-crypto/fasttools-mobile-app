APP_ENV=development
API_PORT=8000
ALLOWED_ORIGINS=*

# Conversion provider
# Recommended for PDF to Word and reliable conversions.
CLOUDCONVERT_API_KEY=

# Optional monitoring
SENTRY_DSN=

# Frontend app origin(s) for CORS. Use comma-separated URLs in production.
# Example: ALLOWED_ORIGINS=https://fasttools.app,https://www.fasttools.app
